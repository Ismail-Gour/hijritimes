{
  "rewrites": [
    { "source": "/((?!assets|favicon\\.ico|robots\\.txt|sitemap\\.xml|placeholder\\.svg).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/((?!assets|.*\\.(js|css|png|jpg|svg|ico|xml|txt|json)).*)",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    }
  ]
}
